{
  "contract_version": 2,
  "description": "Portable, target-explicit manager for Codex configuration and an official target-owned Codex CLI install.",
  "display_name": "NDDev Codex Setup Manager",
  "github_repository": "NDDev-it-com/nddev-codex-app",
  "license": "AGPL-3.0-or-later",
  "manifest_ref": "build/manifest.json",
  "managed_state": {
    "managed_files": [
      "config.toml",
      "AGENTS.md"
    ],
    "managed_file_mode": "0600",
    "preserve_other_state": true,
    "stamp_file": "NDDEV-CODEX-SETUP.json",
    "stamp_schema": 1
  },
  "permission_defaults": {
    "admin_enforcement": false,
    "built_in_profiles_only": true,
    "configuration_precedence_applies": true,
    "custom_permissions_table_used": false
  },
  "product_name": "nddev-codex-app",
  "runtime_compatibility": {
    "baseline_ref": "references/codex-baseline.json",
    "permission_profiles_status": "beta",
    "version_ref": "build/version.json"
  },
  "runtime_launch": {
    "command": "<absolute-target>/bin/codex",
    "direct_command": "CODEX_HOME=<absolute-target> <absolute-target>/bin/codex [args...]",
    "environment_variable": "CODEX_HOME",
    "executable_source": "validated-target-owned-standalone-install",
    "forwards_arguments": true,
    "forwards_child_exit_code": true,
    "json_manager_errors_supported": true,
    "manager_command": "python3 cli-tools/nddev_codex.py launch --target <absolute-target> -- [args...]",
    "requires_clean_managed_target": true,
    "required_version": "0.144.3",
    "streams_child_stdio": true,
    "successful_child_output_wrapped": false,
    "target_environment_scope": "child-process-only",
    "target_must_equal_runtime_home": true
  },
  "safety": {
    "absolute_target_required": true,
    "agents_override_rejected": true,
    "canonical_target_binding": true,
    "default_target": null,
    "explicit_target_required": [
      "status",
      "plan",
      "apply",
      "switch",
      "restore",
      "remove",
      "software-status",
      "install-cli",
      "update-cli",
      "launch",
      "desktop"
    ],
    "max_backups": 10,
    "missing_target_argument_rejected": true,
    "new_target_mode": "0700",
    "preserve_existing_target_mode": true,
    "relative_target_rejected": true,
    "rollback_on_failure": true,
    "target_symlinks_rejected": true
  },
  "setup_system": {
    "catalog_root": "setups",
    "identity_source": "<setup>/setup.json:id",
    "list_command": "python3 cli-tools/nddev_codex.py list [--json]",
    "selection_option": "--setup <id>",
    "setup_ids": [
      "safe",
      "full-auto"
    ],
    "launch_command": "python3 cli-tools/nddev_codex.py launch --target <absolute-target> -- [args...]",
    "status_command": "python3 cli-tools/nddev_codex.py status --target <absolute-dir> [--json]"
  },
  "software_install": {
    "commands": {
      "install": "python3 cli-tools/nddev_codex.py install-cli --target <absolute-target> [--json]",
      "status": "python3 cli-tools/nddev_codex.py software-status --target <absolute-target> [--json]",
      "update": "python3 cli-tools/nddev_codex.py update-cli --target <absolute-target> [--json]"
    },
    "desktop": {
      "command": "python3 cli-tools/nddev_codex.py desktop --target <absolute-target> [--workspace <absolute-dir>]",
      "configuration_binding": "not-guaranteed-by-codex-app",
      "delegate": "codex app",
      "documented_product": "ChatGPT",
      "direct_app_management": false,
      "pinned_cli_packaging": "Codex.app/Codex.dmg",
      "requires_managed_setup": false,
      "supported_platforms": [
        "macos"
      ]
    },
    "installer": {
      "abnormal_exit_cleanup": "terminate-process-group-before-unlock",
      "asset": "install.sh",
      "release_tag": "rust-v0.144.3",
      "sha256": "1154e9daf713aacd1534efca8042bfd6665ad24bc1d1dfd86b8f439fe60a7a5d",
      "size_bytes": 25133,
      "url": "https://github.com/openai/codex/releases/download/rust-v0.144.3/install.sh"
    },
    "layout": {
      "code_mode_host": "packages/standalone/current/bin/codex-code-mode-host",
      "compatibility_entrypoint": "packages/standalone/current/codex",
      "current": "packages/standalone/current",
      "linux_sandbox": "packages/standalone/current/codex-resources/bwrap",
      "metadata": "packages/standalone/current/codex-package.json",
      "releases": "packages/standalone/releases",
      "ripgrep": "packages/standalone/current/codex-path/rg",
      "visible_code_mode_host_macos": "bin/codex-code-mode-host",
      "visible_command": "bin/codex"
    },
    "supported_platforms": [
      "macos",
      "linux"
    ],
    "tested_version": "0.144.3"
  },
  "source_root": "setups",
  "version_ref": "build/version.json"
}
